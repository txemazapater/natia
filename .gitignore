# Ignore build outputs
artifacts/
*.dcu
*.exe
*.local
*.identcache
*.stat
*.dsk
*.skincfg
__history/
__recovery/
*.~*
Thumbs.db
Desktop.ini
.DS_Store

# Delphi IDE output inside project folders (NATIA Studio / VCL clients)
src/apps/**/Win32/
src/apps/**/Win64/
*.rsm

# Generated binary resources next to .dpr/.dproj (keep VCS clean).
# Source graphics under src/apps/studio/common/ ARE versioned (SVG, PNG, ICO, …).
src/apps/**/Delphi/*.res

# Do not ignore studio shared assets or top-level design assets
!src/apps/studio/common/**
!assets/**
!licenses/**
!metadata/**
