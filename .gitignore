# Ignore build outputs
artifacts/
*.dcu
*.exe
*.local
*.identcache
*.stat
*.dsk
*.skincfg
__history/
__recovery/
*.~*

# Delphi IDE output inside project folders (NATIA Studio / VCL clients)
src/apps/**/Win32/
src/apps/**/Win64/
*.rsm

# Generated resources in Delphi projects (keep VCS clean)
src/apps/**/Delphi/*.res
